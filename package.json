{
  "name": "os-drafter",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @os-drafter/shared build",
    "dev": "concurrently -n client,server -c blue,green \"pnpm --filter @os-drafter/client dev\" \"pnpm --filter @os-drafter/server dev\"",
    "build": "pnpm --filter @os-drafter/shared build && pnpm --filter @os-drafter/client build && pnpm --filter @os-drafter/server build",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"]
  }
}
